{
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/approve.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy",  "value": "default-src 'self'; style-src 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self'" }
      ]
    }
  ]
}
