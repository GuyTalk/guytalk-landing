{
  "cleanUrls": true,
  "trailingSlash": false,
  "git": {
    "deploymentEnabled": {
      "pending": false
    }
  },
  "functions": {
    "api/approve.js":         { "maxDuration": 60 },
    "api/preview.js":         { "maxDuration": 30 },
    "api/ticker.js":          { "maxDuration": 15 },
    "api/live.js":            { "maxDuration": 15, "includeFiles": "brief/data/live-culture.json" },
    "api/talk.js":            { "maxDuration": 30, "includeFiles": "brief/data/live-social.json" },
    "api/refresh-culture.js": { "maxDuration": 30 },
    "api/refresh-social.js":  { "maxDuration": 60 },
    "api/beehiiv-sync.js":    { "maxDuration": 15 },
    "api/subscribe.js":       { "maxDuration": 15 },
    "api/quote.js":           { "maxDuration": 15 },
    "api/social-queue.js":    { "maxDuration": 60, "includeFiles": "brief/data/**" },
    "api/founder.js":         { "maxDuration": 15 }
  },
  "crons": [
    { "path": "/api/refresh-culture", "schedule": "0 11 * * *" },
    { "path": "/api/beehiiv-sync",    "schedule": "33 11 * * *" },
    { "path": "/api/social-queue",    "schedule": "0 13 * * *" },
    { "path": "/api/refresh-social",  "schedule": "0 11 * * *" },
    { "path": "/api/refresh-social",  "schedule": "0 17 * * *" },
    { "path": "/api/refresh-social",  "schedule": "0 23 * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",       "value": "nosniff" },
        { "key": "X-Frame-Options",              "value": "DENY" },
        { "key": "X-XSS-Protection",             "value": "1; mode=block" },
        { "key": "Referrer-Policy",              "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",           "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security",    "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.guytalkmedia.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET" }
      ]
    }
  ]
}
